@model UrlShortener.MVC.Models.ShortenedUrlVM
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "URL Details";
    var request = HttpContextAccessor.HttpContext?.Request;
    var baseUrl = $"{request?.Scheme}://{request?.Host}";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0"><i class="bi bi-info-circle"></i> Short URL Details</h4>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Short Code:</dt>
                        <dd class="col-sm-8">
                            <code>@Model.ShortCode</code>
                        </dd>

                        <dt class="col-sm-4">Short URL (Click to test):</dt>
                        <dd class="col-sm-8">
                            <div class="input-group">
                                <a href="@baseUrl/r/@Model.ShortCode" target="_blank" class="form-control text-primary" id="shortUrlLink">
                                    @baseUrl/r/@Model.ShortCode
                                </a>
                                <button class="btn btn-outline-primary" type="button" onclick="copyShortUrl('@baseUrl/r/@Model.ShortCode')">
                                    <i class="bi bi-clipboard"></i> Copy
                                </button>
                            </div>
                        </dd>

                        <dt class="col-sm-4">QR Code:</dt>
                        <dd class="col-sm-8">
                            <div class="text-center p-3 bg-light rounded">
                                <img id="qrCodeImage" src="" alt="QR Code" class="img-fluid mb-2" style="max-width: 250px;" />
                                <br />
                                <div class="alert alert-success small mb-2">
                                    <i class="bi bi-check-circle"></i> 
                                    <strong>QR Code dẫn thẳng đến Original URL</strong>
                                </div>
                                <button type="button" class="btn btn-sm btn-primary" onclick="downloadQRCode()">
                                    <i class="bi bi-download"></i> Download QR Code
                                </button>
                            </div>
                        </dd>

                        <dt class="col-sm-4">Original URL:</dt>
                        <dd class="col-sm-8">
                            <a href="@Model.OriginalUrl" target="_blank" class="text-break">
                                @Model.OriginalUrl <i class="bi bi-box-arrow-up-right"></i>
                            </a>
                        </dd>

                        <dt class="col-sm-4">Title:</dt>
                        <dd class="col-sm-8">@(Model.Title ?? "N/A")</dd>

                        <dt class="col-sm-4">Description:</dt>
                        <dd class="col-sm-8">@(Model.Description ?? "N/A")</dd>

                        <dt class="col-sm-4">Created Date:</dt>
                        <dd class="col-sm-8">@Model.CreatedDate.ToString("MMM dd, yyyy HH:mm")</dd>

                        <dt class="col-sm-4">Expiration Date:</dt>
                        <dd class="col-sm-8">
                            @if (Model.ExpirationDate.HasValue)
                            {
                                @Model.ExpirationDate.Value.ToString("MMM dd, yyyy HH:mm")
                                @if (Model.IsExpired)
                                {
                                    <span class="badge bg-danger">Expired</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">No expiration</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Total Clicks:</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-success fs-6">@Model.ClickCount</span>
                        </dd>

                        <dt class="col-sm-4">Status:</dt>
                        <dd class="col-sm-8">
                            @if (Model.Status == UrlShortener.Common.Enums.UrlStatus.Active)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else if (Model.Status == UrlShortener.Common.Enums.UrlStatus.Inactive)
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                            else if (Model.Status == UrlShortener.Common.Enums.UrlStatus.Expired)
                            {
                                <span class="badge bg-warning">Expired</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Deleted</span>
                            }
                        </dd>
                    </dl>

                    <div class="d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var shortCode = '@Model.ShortCode';
        
        // Generate QR Code on page load - QR dẫn thẳng đến Original URL
        document.addEventListener('DOMContentLoaded', function() {
            fetch('/UrlShortener/GenerateQRCode?id=@Model.Id')
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById('qrCodeImage').src = data.qrCode;
                        window.currentQRCode = data.qrCode;
                    }
                })
                .catch(error => console.error('Error:', error));
        });

        function copyShortUrl(url) {
            navigator.clipboard.writeText(url);
            
            // Show feedback
            const btn = event.target.closest('button');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="bi bi-check"></i> Copied!';
            btn.classList.remove('btn-outline-primary');
            btn.classList.add('btn-success');
            
            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.classList.remove('btn-success');
                btn.classList.add('btn-outline-primary');
            }, 2000);
        }

        function downloadQRCode() {
            if (window.currentQRCode) {
                const link = document.createElement('a');
                link.href = window.currentQRCode;
                link.download = 'QRCode_OriginalURL_' + shortCode + '.png';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            }
        }
    </script>
}
