name: dockercompose13510592969709114298
services:
  redis-cache:
    image: redis:7.4
    networks:
      default: null
    ports:
      - mode: ingress
        target: 6379
        published: "6379"
        protocol: tcp
    restart: unless-stopped
    volumes:
      - type: volume
        source: redis-data
        target: /data
        volume: {}
  sql2025:
    container_name: sql2025
    environment:
      ACCEPT_EULA: "Y"
      SA_PASSWORD: StrongPassword123
    healthcheck:
      test:
        - CMD
        - /opt/mssql-tools18/bin/sqlcmd
        - -S
        - localhost
        - -U
        - sa
        - -P
        - StrongPassword123
        - -Q
        - SELECT 1
        - -C
      timeout: 5s
      interval: 10s
      retries: 10
      start_period: 30s
    image: mcr.microsoft.com/mssql/server:2025-latest
    networks:
      default: null
    ports:
      - mode: ingress
        target: 1433
        published: "1433"
        protocol: tcp
    restart: unless-stopped
    volumes:
      - type: volume
        source: sqlserver-data
        target: /var/opt/mssql
        volume: {}
  web:
    build:
      context: D:\Thay  CanhHT5\CW DM\UrlShortener
      dockerfile: UrlShortener.MVC/Dockerfile
    depends_on:
      redis-cache:
        condition: service_started
        required: true
      sql2025:
        condition: service_healthy
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_URLS: http://+:8080
      ConnectionStrings__DefaultConnection: Server=sql2025,1433;Database=UrlShortener;User Id=sa;Password=StrongPassword123;TrustServerCertificate=True;
      ConnectionStrings__IdentityConnection: Server=sql2025,1433;Database=UrlShortenerIdentity;User Id=sa;Password=StrongPassword123;TrustServerCertificate=True;
      ConnectionStrings__Redis: redis-cache:6379
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "8080"
        protocol: tcp
    restart: on-failure
networks:
  default:
    name: dockercompose13510592969709114298_default
volumes:
  redis-data:
    name: dockercompose13510592969709114298_redis-data
  sqlserver-data:
    name: dockercompose13510592969709114298_sqlserver-data