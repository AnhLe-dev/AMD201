@model IEnumerable<UrlShortener.MVC.Models.ShortenedUrlVM>

@{
    ViewData["Title"] = "URL Shortener";
    var isAdmin = ViewBag.IsAdmin ?? false;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h1 class="mb-4">
                <i class="bi bi-link-45deg"></i> URL Shortener
                @if (isAdmin)
                {
                    <span class="badge bg-danger">Admin View - All URLs</span>
                }
                else
                {
                    <span class="badge bg-primary">My URLs</span>
                }
            </h1>
            
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-circle"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-plus-circle"></i> Create Short URL</h5>
                </div>
                <div class="card-body">
                    <p>
                        <a class="btn btn-primary" asp-action="Create">
                            <i class="bi bi-plus-lg"></i> Create New Short URL
                        </a>
                    </p>
                    <div class="text-muted small">
                        <p><i class="bi bi-info-circle"></i> Shorten your long URLs quickly and easily! Each short URL comes with a QR code.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-list-ul"></i> 
                        @if (isAdmin)
                        {
                            <text>All Short URLs</text>
                        }
                        else
                        {
                            <text>Your Short URLs</text>
                        }
                    </h5>
                    <button class="btn btn-sm btn-light" onclick="reloadUrlList()">
                        <i class="bi bi-arrow-clockwise"></i> Refresh
                    </button>
                </div>
                <div class="card-body" id="urlListContainer">
                    @await Component.InvokeAsync("UrlList")
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-dismiss alerts after 5 seconds
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);

        function reloadUrlList() {
            $.ajax({
                url: '/UrlShortener/RefreshList',
                type: 'GET',
                beforeSend: function() {
                    $('#urlListContainer').html('<div class="text-center"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div></div>');
                },
                success: function(response) {
                    $('#urlListContainer').html(response);
                },
                error: function() {
                    $('#urlListContainer').html('<div class="alert alert-danger">Failed to reload URL list</div>');
                }
            });
        }
    </script>
}
